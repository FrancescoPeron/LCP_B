    "from sklearn.model_selection import StratifiedKFold\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "import keras_tuner\n",
    "from keras.callbacks import EarlyStopping\n",
    "from sklearn.metrics import roc_auc_score, classification_report\n",
    "\n",
    "outer_kf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "oof_preds = np.zeros(len(x))\n",
    "\n",
    "for fold, (train_idx, test_idx) in enumerate(outer_kf.split(x, y)):\n",
    "    X_train, X_test = x[train_idx], x[test_idx]\n",
    "    y_train, y_test = y[train_idx], y[test_idx]\n",
    "\n",
    "    # Scaler fit solo su train\n",
    "    scaler = StandardScaler()\n",
    "    X_train = scaler.fit_transform(X_train)\n",
    "    X_test  = scaler.transform(X_test)\n",
    "\n",
    "    # ✅ Tuner SOLO su X_train (mai vede X_test)\n",
    "    tuner = keras_tuner.RandomSearch(\n",
    "        build_model,\n",
    "        objective='val_loss',\n",
    "        max_trials=10,\n",
    "        directory=f'tuner_fold_{fold}',\n",
    "        overwrite=True\n",
    "    )\n",
    "    tuner.search(X_train, y_train,\n",
    "                 epochs=50,\n",
    "                 validation_split=0.2,  # split interno a X_train\n",
    "                 callbacks=[EarlyStopping(patience=5)])\n",
    "\n",
    "    best_hp = tuner.get_best_hyperparameters()[0]\n",
    "\n",
    "    # Riaddestra con i best HP su tutto X_train\n",
    "    model = tuner.hypermodel.build(best_hp)\n",
    "    model.fit(X_train, y_train, epochs=100,\n",
    "              callbacks=[EarlyStopping(patience=10, restore_best_weights=True)])\n",
    "\n",
    "    oof_preds[test_idx] = model.predict(X_test).ravel()\n",
    "\n",
    "print(f\"Nested CV AUC: {roc_auc_score(y, oof_preds):.4f}\")"
   ]
  },
